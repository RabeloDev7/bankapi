# ── Line endings ──────────────────────────────────────────────────────────────
# Padrao: normaliza tudo para LF no repositorio
* text=auto

# Arquivos que DEVEM ter LF mesmo no Windows (scripts Linux/Docker)
*.sh    text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf

# Arquivos que podem ter CRLF no Windows
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binarios — sem conversao
*.jar   binary
*.png   binary
*.jpg   binary
*.ico   binary

# ── GitHub Linguist ───────────────────────────────────────────────────────────
# Ignora frontend estatico na contagem de linguagem
src/main/resources/static/**/*.html linguist-vendored=true
src/main/resources/static/**/*.css  linguist-vendored=true
src/main/resources/static/**/*.js   linguist-vendored=true

# Documentacao e config nao contam como linguagem
*.md            linguist-documentation=true
*.yml           linguist-documentation=true
*.xml           linguist-documentation=true
*.properties    linguist-documentation=true
